+#import <AVFoundation/AVFoundation.h>
+#import <CoreGraphics/CoreGraphics.h>
+#import <CoreImage/CoreImage.h>
+#import <QuartzCore/QuartzCore.h>
+#import <Metal/Metal.h>
+#import <TargetConditionals.h>
+
+#if TARGET_OS_IPHONE
+#import <UIKit/UIKit.h>
+#else
+#import <AppKit/AppKit.h>
+#endif
+
+struct avf_render_geometry {
+    int w, h;
+    struct mp_rect src, dst;
+    struct mp_osd_res osd_res;
+};
+
+enum avf_osd_draw_path {
+    AVF_OSD_DRAW_NONE = 0,
+    AVF_OSD_DRAW_DIRECT_LIBASS,
+    AVF_OSD_DRAW_DIRECT_BGRA,
+    AVF_OSD_DRAW_COREGRAPHICS,
+};
+
+struct avfoundation_opts {
+    bool composite_osd;
+    bool pip_composite_osd;
+    int queue_lead_ms;
+};
+
+struct priv {
+    struct mp_hwdec_ctx hwctx;
+    struct m_config_cache *opts_cache;
+    struct avfoundation_opts *opts;
+
+    struct mp_image *next_image;
+    double next_pts;
+    CMTimebaseRef timebase;
+    int64_t next_present_host_ns;
+    int64_t next_media_pts_ns;
+    bool next_media_pts_valid;
+    __strong AVSampleBufferDisplayLayer *displayLayer;
+
+    // OSD/Subtitle support (timed AVSampleBufferDisplayLayer overlay mode)
+    __strong AVSampleBufferDisplayLayer *osdLayer;
+    int64_t osd_change_id;
+    int osd_w, osd_h;
+    struct mp_osd_res osd_res;
+    struct avf_render_geometry render_geometry;
+    bool render_geometry_valid;
+    CVPixelBufferPoolRef osdPool;
+    int osd_pool_w, osd_pool_h;
+    bool osd_needs_enqueue;
+
+    // Compositing mode support
+    __strong id<MTLDevice> mtlDevice;
+    __strong CIContext *ciContext;
+    CVPixelBufferPoolRef outputPool;
+    int output_pool_w, output_pool_h;
+    OSType output_pool_format;
+    CGImageRef cachedSubtitleImage;
+    CVPixelBufferRef cachedSubtitleBuffer;
+    int subtitle_x0, subtitle_y0, subtitle_x1, subtitle_y1;
+    bool has_subtitle;
+
+    // Software frame upload support
+    CVPixelBufferPoolRef swUploadPool;
+    int sw_pool_w, sw_pool_h;
+    OSType sw_pool_format;
+
+    // Frame counter for periodic maintenance
+    int frame_count;
+    int not_ready_drop_count;
+    int64_t last_not_ready_drop_ns;
+    int64_t last_display_recovery_ns;
+    int64_t last_video_enqueue_ns;
+    int64_t last_media_pts_ns;
+    int64_t last_present_host_ns;
+    bool last_media_pts_valid;
+    bool timebase_anchor_valid;
+    bool timebase_paused;
+    bool playback_paused;
+    double timebase_rate;
+
+    // Track if OSD callback was invoked this frame
+    bool osd_callback_invoked;
+
+    // Track whether the previous frame was rendered through Core Image for
+    // video geometry so the layer can recover cleanly when zoom is reset.
+    bool applied_geometry_last_frame;
+
+    // Avoid logging every frame if geometry rendering repeatedly fails.
+    bool geometry_render_failure_logged;
+
+};
+
+static CGFloat get_screen_scale(void)
+{
+#if TARGET_OS_IPHONE
+    return [UIScreen mainScreen].scale;
+#else
+    NSScreen *screen = [NSScreen mainScreen];
+    return screen ? screen.backingScaleFactor : 1.0;
+#endif
+}
+
+static void dispatch_main_sync_safe(dispatch_block_t block);
+static void clear_subtitle_cache(struct priv *p);
+static void release_ci_compositor(struct priv *p);
+static const struct m_sub_options avfoundation_conf;
+
+static bool should_composite_into_video(struct priv *p)
+{
+    return p->opts && (p->opts->composite_osd || p->opts->pip_composite_osd);
+}
+
+static bool should_use_inline_osd_layer(struct priv *p)
+{
+    return !should_composite_into_video(p);
+}
+
+static bool should_apply_video_geometry(struct vo *vo)
+{
+    struct mp_vo_opts *opts = vo->opts;
+    // Only per-frame geometry options use Core Image; panscan and aspect
+    // override stay on the sample-buffer/videoGravity path.
+    return opts && (fabsf(opts->zoom) > 0.0001f ||
+                    fabsf(opts->pan_x) > 0.0001f ||
+                    fabsf(opts->pan_y) > 0.0001f ||
+                    fabsf(opts->scale_x - 1.0f) > 0.0001f ||
+                    fabsf(opts->scale_y - 1.0f) > 0.0001f);
+}
+
+static bool is_p010_format(OSType format)
+{
+    return format == kCVPixelFormatType_420YpCbCr10BiPlanarVideoRange ||
+           format == kCVPixelFormatType_420YpCbCr10BiPlanarFullRange;
+}
+
+static bool is_nv12_format(OSType format)
+{
+    return format == kCVPixelFormatType_420YpCbCr8BiPlanarVideoRange ||
+           format == kCVPixelFormatType_420YpCbCr8BiPlanarFullRange;
+}
+
+static bool is_biplanar_yuv_format(OSType format)
+{
+    return is_nv12_format(format) || is_p010_format(format);
+}
+
+static bool is_full_range_yuv_format(OSType format)
+{
+    return format == kCVPixelFormatType_420YpCbCr8BiPlanarFullRange ||
+           format == kCVPixelFormatType_420YpCbCr10BiPlanarFullRange;
+}
+
+static id<AVQueuedSampleBufferRendering> active_sample_buffer_renderer(
+    AVSampleBufferDisplayLayer *displayLayer)
+{
+    if (!displayLayer)
+        return nil;
+
+    if (@available(iOS 17.0, tvOS 17.0, macOS 14.0, *))
+        return displayLayer.sampleBufferRenderer;
+
+    return displayLayer;
+}
+
+static AVQueuedSampleBufferRenderingStatus sample_buffer_renderer_status(
+    AVSampleBufferDisplayLayer *displayLayer)
+{
+    if (!displayLayer)
+        return AVQueuedSampleBufferRenderingStatusUnknown;
+
+    if (@available(iOS 17.0, tvOS 17.0, macOS 14.0, *))
+        return displayLayer.sampleBufferRenderer.status;
+
+    return displayLayer.status;
+}
+
+static bool sample_buffer_renderer_requires_flush(
+    AVSampleBufferDisplayLayer *displayLayer)
+{
+    if (!displayLayer)
+        return false;
+
+    if (@available(iOS 17.0, tvOS 17.0, macOS 14.0, *))
+        return displayLayer.sampleBufferRenderer.requiresFlushToResumeDecoding;
+
+    if (@available(iOS 14.0, tvOS 14.0, macOS 11.0, *))
+        return displayLayer.requiresFlushToResumeDecoding;
+
+    return false;
+}
+
+static bool sample_buffer_renderer_is_ready(AVSampleBufferDisplayLayer *displayLayer)
+{
+    id<AVQueuedSampleBufferRendering> renderer =
+        active_sample_buffer_renderer(displayLayer);
+    return renderer && renderer.isReadyForMoreMediaData;
+}
+
+static bool media_pts_is_valid(double pts)
+{
+    return pts != MP_NOPTS_VALUE && isfinite(pts);
+}
+
+static int64_t media_pts_to_ns(double pts)
+{
+    return (int64_t)(pts * (double)NSEC_PER_SEC + (pts >= 0 ? 0.5 : -0.5));
+}
+
+static CMTime cm_time_from_ns(int64_t ns)
+{
+    return CMTimeMake(ns, NSEC_PER_SEC);
+}
+
+static int64_t cm_time_to_ns(CMTime time)
+{
+    if (!CMTIME_IS_NUMERIC(time))
+        return 0;
+
+    CMTime converted = CMTimeConvertScale(time, NSEC_PER_SEC,
+                                          kCMTimeRoundingMethod_Default);
+    return converted.value;
+}
+
+static int64_t current_media_time_ns(struct priv *p)
+{
+    if (p->next_media_pts_valid)
+        return p->next_media_pts_ns;
+    if (p->last_media_pts_valid)
+        return p->last_media_pts_ns;
+    if (p->timebase)
+        return cm_time_to_ns(CMTimebaseGetTime(p->timebase));
+    return 0;
+}
+
+static void reset_media_timing(struct priv *p)
+{
+    p->next_media_pts_ns = 0;
+    p->next_media_pts_valid = false;
+    p->last_media_pts_ns = 0;
+    p->last_present_host_ns = 0;
+    p->last_media_pts_valid = false;
+    p->timebase_anchor_valid = false;
+    p->timebase_paused = false;
+    p->playback_paused = false;
+    p->timebase_rate = 1.0;
+}
+
+static double infer_timebase_rate(struct priv *p, int64_t media_pts_ns,
+                                  int64_t present_host_ns)
+{
+    double rate = p->timebase_rate > 0.0 ? p->timebase_rate : 1.0;
+
+    if (!p->last_media_pts_valid || !p->last_present_host_ns)
+        return rate;
+
+    int64_t media_delta = media_pts_ns - p->last_media_pts_ns;
+    int64_t host_delta = present_host_ns - p->last_present_host_ns;
+    if (media_delta <= 0 || host_delta <= MP_TIME_MS_TO_NS(5))
+        return rate;
+
+    double inferred = (double)media_delta / (double)host_delta;
+    return inferred >= 0.05 && inferred <= 8.0 ? inferred : rate;
+}
+
+static void update_media_timebase_for_frame(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+    if (!p->timebase || !p->next_media_pts_valid)
+        return;
+
+    int64_t now = mp_time_ns();
+    int64_t present_host_ns = p->next_present_host_ns > 0
+        ? p->next_present_host_ns
+        : now;
+    int64_t media_pts_ns = p->next_media_pts_ns;
+    double rate = p->playback_paused
+        ? 0.0
+        : infer_timebase_rate(p, media_pts_ns, present_host_ns);
+
+    bool should_anchor = !p->timebase_anchor_valid || p->timebase_paused ||
+        p->playback_paused || fabs(rate - p->timebase_rate) > 0.01;
+
+    if (!should_anchor) {
+        int64_t timebase_ns = cm_time_to_ns(CMTimebaseGetTime(p->timebase));
+        int64_t projected_ns = timebase_ns +
+            (int64_t)((double)(present_host_ns - now) * p->timebase_rate);
+        should_anchor = llabs(projected_ns - media_pts_ns) > MP_TIME_MS_TO_NS(20);
+    }
+
+    if (should_anchor) {
+        OSStatus err = CMTimebaseSetRateAndAnchorTime(
+            p->timebase, rate, cm_time_from_ns(media_pts_ns),
+            cm_time_from_ns(present_host_ns));
+        if (err != noErr) {
+            MP_WARN(vo, "Failed to anchor AVFoundation media timebase: %d\n", (int)err);
+        }
+        p->timebase_rate = rate;
+        p->timebase_anchor_valid = true;
+        p->timebase_paused = p->playback_paused;
+    }
+
+    p->last_media_pts_ns = media_pts_ns;
+    p->last_present_host_ns = present_host_ns;
+    p->last_media_pts_valid = true;
+}
+
+static void set_media_timebase_paused(struct vo *vo, bool paused)
+{
+    struct priv *p = vo->priv;
+    if (!p->timebase)
+        return;
+    p->playback_paused = paused;
+
+    if (paused) {
+        CMTime media_time = CMTimebaseGetTime(p->timebase);
+        if (!CMTIME_IS_NUMERIC(media_time)) {
+            media_time = cm_time_from_ns(p->last_media_pts_valid
+                ? p->last_media_pts_ns
+                : 0);
+        }
+        OSStatus err = CMTimebaseSetRateAndAnchorTime(
+            p->timebase, 0.0, media_time, cm_time_from_ns(mp_time_ns()));
+        if (err != noErr)
+            MP_WARN(vo, "Failed to pause AVFoundation media timebase: %d\n", (int)err);
+        p->timebase_paused = true;
+        return;
+    }
+
+    p->timebase_paused = false;
+    p->timebase_anchor_valid = false;
+}
+
+static void sample_buffer_renderer_flush(AVSampleBufferDisplayLayer *displayLayer,
+                                         bool remove_image)
+{
+    if (!displayLayer)
+        return;
+
+    if (@available(iOS 17.0, tvOS 17.0, macOS 14.0, *)) {
+        AVSampleBufferVideoRenderer *renderer = displayLayer.sampleBufferRenderer;
+        if (remove_image) {
+            [renderer flushWithRemovalOfDisplayedImage:YES completionHandler:NULL];
+        } else {
+            [renderer flush];
+        }
+        return;
+    }
+
+    if (remove_image) {
+        [displayLayer flushAndRemoveImage];
+    } else {
+        [displayLayer flush];
+    }
+}
+
+static void sample_buffer_renderer_enqueue(AVSampleBufferDisplayLayer *displayLayer,
+                                           CMSampleBufferRef buf)
+{
+    id<AVQueuedSampleBufferRendering> renderer =
+        active_sample_buffer_renderer(displayLayer);
+    [renderer enqueueSampleBuffer:buf];
+}
+
+static bool display_layer_needs_recovery(AVSampleBufferDisplayLayer *displayLayer)
+{
+    if (!displayLayer)
+        return false;
+
+    return sample_buffer_renderer_status(displayLayer) ==
+               AVQueuedSampleBufferRenderingStatusFailed ||
+           sample_buffer_renderer_requires_flush(displayLayer);
+}
+
+static void recover_display_layer(struct vo *vo, const char *reason)
+{
+    struct priv *p = vo->priv;
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+
+    if (!displayLayer) {
+        [osdLayer release];
+        return;
+    }
+
+    int64_t now = mp_time_ns();
+    if (p->last_display_recovery_ns &&
+        now - p->last_display_recovery_ns < MP_TIME_MS_TO_NS(500)) {
+        [displayLayer release];
+        [osdLayer release];
+        return;
+    }
+    p->last_display_recovery_ns = now;
+
+    __block AVQueuedSampleBufferRenderingStatus status =
+        AVQueuedSampleBufferRenderingStatusUnknown;
+    __block bool requires_flush = false;
+    __block bool ready = false;
+    __block int64_t timebase_ns = 0;
+    __block double timebase_rate = 0.0;
+
+    dispatch_main_sync_safe(^{
+        status = sample_buffer_renderer_status(displayLayer);
+        requires_flush = sample_buffer_renderer_requires_flush(displayLayer);
+        ready = sample_buffer_renderer_is_ready(displayLayer);
+        if (p->timebase) {
+            timebase_ns = cm_time_to_ns(CMTimebaseGetTime(p->timebase));
+            timebase_rate = CMTimebaseGetRate(p->timebase);
+        }
+
+        sample_buffer_renderer_flush(displayLayer, false);
+        sample_buffer_renderer_flush(osdLayer, false);
+    });
+
+    MP_WARN(vo, "Recovered AVFoundation display layer after %s "
+                "(status=%ld, requiresFlush=%s, ready=%s, "
+                "mediaPts=%.3f, timebase=%.3f, rate=%.3f)\n",
+            reason, (long)status, requires_flush ? "yes" : "no",
+            ready ? "yes" : "no",
+            current_media_time_ns(p) / 1000000000.0,
+            timebase_ns / 1000000000.0, timebase_rate);
+
+    p->not_ready_drop_count = 0;
+    p->last_not_ready_drop_ns = 0;
+    p->last_video_enqueue_ns = 0;
+    p->timebase_anchor_valid = false;
+    p->timebase_paused = p->playback_paused;
+    p->osd_change_id = 0;
+    p->osd_needs_enqueue = false;
+
+    [displayLayer release];
+    [osdLayer release];
+}
+
+static void record_not_ready_drop(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+    int64_t now = mp_time_ns();
+
+    if (p->last_not_ready_drop_ns == 0 ||
+        now - p->last_not_ready_drop_ns > MP_TIME_MS_TO_NS(500))
+        p->not_ready_drop_count = 0;
+
+    p->last_not_ready_drop_ns = now;
+    p->not_ready_drop_count++;
+
+    if (p->not_ready_drop_count >= 3 &&
+        (!p->last_video_enqueue_ns ||
+         now - p->last_video_enqueue_ns >= MP_TIME_MS_TO_NS(500)))
+        recover_display_layer(vo, "repeated not-ready drops");
+}
+
+static void update_avfoundation_geometry(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    if (!p->displayLayer)
+        return;
+
+    __block int width = 0;
+    __block int height = 0;
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    dispatch_main_sync_safe(^{
+        CGFloat scale = displayLayer.contentsScale > 0 ? displayLayer.contentsScale : get_screen_scale();
+        CGSize size = displayLayer.bounds.size;
+        if (size.width <= 0 || size.height <= 0)
+            size = displayLayer.frame.size;
+
+        width = MPMAX(1, (int)(size.width * scale + 0.5));
+        height = MPMAX(1, (int)(size.height * scale + 0.5));
+    });
+    [displayLayer release];
+
+    vo->dwidth = width;
+    vo->dheight = height;
+    vo->monitor_par = 1.0;
+}
+
+static struct avf_render_geometry compute_render_geometry(struct vo *vo,
+                                                          int frame_w,
+                                                          int frame_h)
+{
+    struct priv *p = vo->priv;
+    struct mp_rect src, dst;
+    struct mp_osd_res vo_osd;
+
+    vo_get_src_dst_rects(vo, &src, &dst, &vo_osd);
+
+    if (frame_w <= 0)
+        frame_w = vo->params ? vo->params->w : 0;
+    if (frame_h <= 0)
+        frame_h = vo->params ? vo->params->h : 0;
+
+    if (should_use_inline_osd_layer(p)) {
+        return (struct avf_render_geometry){
+            .w = vo_osd.w,
+            .h = vo_osd.h,
+            .src = src,
+            .dst = dst,
+            .osd_res = vo_osd,
+        };
+    }
+
+    if (frame_w <= 0 || frame_h <= 0 || vo_osd.w <= 0 || vo_osd.h <= 0) {
+        return (struct avf_render_geometry){0};
+    }
+
+    int params_w = vo->params ? vo->params->w : frame_w;
+    int params_h = vo->params ? vo->params->h : frame_h;
+    if (src.x1 <= src.x0 || src.y1 <= src.y0) {
+        src = (struct mp_rect){0, 0, params_w, params_h};
+    }
+
+    return (struct avf_render_geometry){
+        .w = vo_osd.w,
+        .h = vo_osd.h,
+        .src = src,
+        .dst = dst,
+        .osd_res = vo_osd,
+    };
+}
+
+static void invalidate_render_geometry(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+    p->render_geometry_valid = false;
+}
+
+static void update_render_geometry(struct vo *vo, int frame_w, int frame_h)
+{
+    struct priv *p = vo->priv;
+
+    if (frame_w <= 0)
+        frame_w = vo->params ? vo->params->w : 0;
+    if (frame_h <= 0)
+        frame_h = vo->params ? vo->params->h : 0;
+
+    update_avfoundation_geometry(vo);
+    p->render_geometry = compute_render_geometry(vo, frame_w, frame_h);
+    p->render_geometry_valid = true;
+}
+
+static struct avf_render_geometry get_render_geometry(struct vo *vo,
+                                                      int frame_w,
+                                                      int frame_h)
+{
+    struct priv *p = vo->priv;
+
+    if (!p->render_geometry_valid || should_apply_video_geometry(vo))
+        update_render_geometry(vo, frame_w, frame_h);
+
+    return p->render_geometry;
+}
+
+// Helper to sync OSD layer frame with display layer frame.
+static void sync_osd_layer_frame(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    update_avfoundation_geometry(vo);
+    invalidate_render_geometry(vo);
+
+    if (!should_use_inline_osd_layer(p) || !p->osdLayer || !p->displayLayer)
+        return;
+    AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    if (!osdLayer || !displayLayer) {
+        [osdLayer release];
+        [displayLayer release];
+        return;
+    }
+    dispatch_async(dispatch_get_main_queue(), ^{
+        [CATransaction begin];
+        [CATransaction setDisableActions:YES];
+        if (osdLayer.superlayer == displayLayer) {
+            osdLayer.frame = displayLayer.bounds;
+        } else {
+            osdLayer.frame = displayLayer.frame;
+            osdLayer.zPosition = displayLayer.zPosition + 1;
+        }
+        osdLayer.contentsScale = displayLayer.contentsScale > 0 ? displayLayer.contentsScale : get_screen_scale();
+        osdLayer.videoGravity = AVLayerVideoGravityResize;
+        [CATransaction commit];
+        [osdLayer release];
+        [displayLayer release];
+    });
+}
