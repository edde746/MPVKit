+static void update_subtitle_bounds(struct priv *p, CVPixelBufferRef subtitle)
+{
+    p->subtitle_x0 = p->osd_w;
+    p->subtitle_y0 = p->osd_h;
+    p->subtitle_x1 = 0;
+    p->subtitle_y1 = 0;
+
+    if (!subtitle || p->osd_w <= 0 || p->osd_h <= 0)
+        return;
+
+    if (CVPixelBufferLockBaseAddress(subtitle, kCVPixelBufferLock_ReadOnly) != kCVReturnSuccess)
+        return;
+
+    uint8_t *base = CVPixelBufferGetBaseAddress(subtitle);
+    size_t stride = CVPixelBufferGetBytesPerRow(subtitle);
+    if (base && stride) {
+        for (int y = 0; y < p->osd_h; y++) {
+            uint8_t *row = base + (size_t)y * stride;
+            for (int x = 0; x < p->osd_w; x++) {
+                if (row[(size_t)x * 4 + 3]) {
+                    p->subtitle_x0 = MPMIN(p->subtitle_x0, x);
+                    p->subtitle_y0 = MPMIN(p->subtitle_y0, y);
+                    p->subtitle_x1 = MPMAX(p->subtitle_x1, x + 1);
+                    p->subtitle_y1 = MPMAX(p->subtitle_y1, y + 1);
+                }
+            }
+        }
+    }
+
+    CVPixelBufferUnlockBaseAddress(subtitle, kCVPixelBufferLock_ReadOnly);
+}
