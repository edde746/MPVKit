+// Consume a pending host-layer resize flagged by MPVLayerGeometryObserver.
+static void handle_layer_geometry_change(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    // Composite mode draws the OSD into the video samples, which follow the
+    // layer via videoGravity; skipping here also keeps system-driven PiP
+    // window resizes from rescaling PiP subtitles. Inline geometry is
+    // re-read when composite-osd flips back anyway.
+    if (!should_use_inline_osd_layer(p))
+        return;
+
+    MP_VERBOSE(vo, "Host layer resized; resyncing OSD geometry\n");
+
+    clear_subtitle_cache(p);
+    if (p->osdLayer)
+        sample_buffer_renderer_flush(p->osdLayer, true);
+    sync_osd_layer_frame(vo);
+    // Repaint promptly even while paused so a rotation doesn't leave the
+    // old-geometry subtitle on screen until the next natural frame.
+    vo->want_redraw = true;
+}
