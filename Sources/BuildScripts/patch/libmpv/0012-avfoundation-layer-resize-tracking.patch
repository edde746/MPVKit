+// KVO observer for host-driven resizes of the --wid display layer. The
+// callback runs on whatever thread mutates the layer (the app's main
+// thread); it must only flag the change and wake the VO thread.
+@interface MPVLayerGeometryObserver : NSObject {
+@public
+    struct vo *vo;
+}
+@end
+
+@implementation MPVLayerGeometryObserver
+- (void)observeValueForKeyPath:(NSString *)keyPath
+                      ofObject:(id)object
+                        change:(NSDictionary *)change
+                       context:(void *)context
+{
+    // KVO fires on every setter call; only real changes matter. A spurious
+    // resync flushes the OSD layer, blinking any displayed subtitle.
+    id oldValue = change[NSKeyValueChangeOldKey];
+    id newValue = change[NSKeyValueChangeNewKey];
+    if (oldValue && newValue && [oldValue isEqual:newValue])
+        return;
+
+    struct vo *target = self->vo;
+    if (!target)
+        return;
+    struct priv *p = target->priv;
+    atomic_store(&p->pending_layer_geometry_sync, true);
+    vo_wakeup(target);
+}
+@end
